# =============================================================
# Configurazione keycloak-user-panel
# Copia in .env e compila i valori per lo sviluppo locale.
# In produzione le variabili vengono iniettate da ASP-WS apps
# management (compresa BASE_PATH).
#
# IMPORTANTE: il client Keycloak NON deve avere ruoli admin.
# L'app usa SOLO l'Account API di Keycloak con l'access token
# dell'utente loggato. Nessun service-account, nessun accesso
# privilegiato.
# =============================================================

# Porta server (ASP-WS forza 3000 in container)
PORT=3000

# Sessione: stringa lunga random, segreta
SESSION_SECRET=cambia-questa-stringa-con-una-random-lunga-almeno-64-char

# Configurazione OIDC verso Keycloak
KEYCLOAK_ISSUER=https://login.asp.messina.it/realms/asp
KEYCLOAK_REALM=asp
KEYCLOAK_CLIENT_ID=keycloak-user-panel
KEYCLOAK_CLIENT_SECRET=

# URL pubblico dell'app (usato per redirect_uri).
# In produzione: https://ws1.asp.messina.it/apps/keycloak-user-panel
# In locale (dev): http://localhost:3000
APP_PUBLIC_URL=https://ws1.asp.messina.it/apps/keycloak-user-panel

# Dev mode: true allenta i check di cookie security per http://localhost
DEV_MODE=false
